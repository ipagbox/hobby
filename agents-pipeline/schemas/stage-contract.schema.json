{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stage-contract.schema.json",
  "title": "Stage Contract",
  "description": "Мета-схема для валидации файлов pipeline/contracts/*.yaml",
  "type": "object",
  "required": ["stage_id", "name", "role", "goal", "inputs", "outputs", "allowed_sources", "completion_criteria", "risks"],
  "properties": {
    "stage_id": { "type": "string" },
    "name": { "type": "string" },
    "role": { "type": "string" },
    "goal": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "path", "required"],
        "properties": {
          "key": { "type": "string" },
          "path": { "type": "string" },
          "required": { "type": "boolean" },
          "schema": { "type": ["string", "null"] },
          "description": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "path"],
        "properties": {
          "key": { "type": "string" },
          "path": { "type": "string" },
          "schema": { "type": ["string", "null"] },
          "description": { "type": "string" }
        }
      }
    },
    "allowed_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["artifact", "reasoning", "web_search"]
      }
    },
    "review_required": { "type": "boolean" },
    "review_reason": { "type": "string" },
    "completion_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
